# Public site URL (used for magic link redirects, Stripe webhooks, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key is SERVER-ONLY. Never expose it.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Maps / Routing ----------------------------------------------------------
# OSRM router base URL. The public demo (https://router.project-osrm.org)
# is rate-limited and not for production.
OSRM_BASE_URL=https://router.project-osrm.org
# Nominatim geocoder (forward + reverse). Public instance is rate-limited.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# --- Payments ----------------------------------------------------------------
# Set PAYMENT_PROVIDER to "stripe" or "mock". "mock" is safe for development.
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- App config --------------------------------------------------------------
# Default currency (ISO 4217). MWK = Malawian Kwacha.
NEXT_PUBLIC_DEFAULT_CURRENCY=MWK
# Default map center (Lilongwe, Malawi).
NEXT_PUBLIC_DEFAULT_LAT=-13.9626
NEXT_PUBLIC_DEFAULT_LNG=33.7741
# How frequently driver clients publish their location, in ms.
NEXT_PUBLIC_DRIVER_LOCATION_INTERVAL_MS=5000
# Driver-search radius in km used by ride matching.
RIDE_MATCH_RADIUS_KM=8
